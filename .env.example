# Local-only beta defaults. Copy to .env and change passwords before any shared use.
RESOURCESPACE_PORT=8088

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=resourcespace
MYSQL_USER=resourcespace
MYSQL_PASSWORD=change-me-resourcespace

# Optional, for future ResourceSpace API automation.
RS_BASE_URL=http://localhost:8088
RS_API_USER=
RS_API_KEY=

# Preferred ResourceSpace server-only names. Do not prefix secrets with NEXT_PUBLIC.
RESOURCESPACE_BASE_URL=http://localhost:8088
RESOURCESPACE_API_USER=
RESOURCESPACE_API_KEY=
RESOURCESPACE_FIELD_MAP_JSON=
RESOURCESPACE_API_PAGE_SIZE=500
RESOURCESPACE_API_MAX_PAGES=10000
RESOURCESPACE_DEFAULT_COLLECTION_ID=
RESOURCESPACE_ENABLE_WRITEBACK=0
RESOURCESPACE_WRITEBACK_MODE=queued

# Storage / custody readiness. Server-only.
S3_BUCKET=
S3_REGION=
S3_ACCESS_ROLE=
S3_PREVIEW_PREFIX=
S3_ORIGINAL_PREFIX=

GOOGLE_SHARED_DRIVE_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Identity / analytics readiness. Server-only unless explicitly documented otherwise.
SSO_PROVIDER=
SSO_CLIENT_ID=
SSO_TRUSTED_HEADERS=0
SSO_ROLE_MAP_JSON=
PRODUCTION_REQUIRE_TRUSTED_IDENTITY=1
PORTAL_ALLOW_BETA_ROLE_OVERRIDE=1
PORTAL_USAGE_LOGGING=0
USAGE_ANALYTICS_DSN=
USAGE_ANALYTICS_DB_PATH=
RUNTIME_STORE=local-filesystem
BETA_FEEDBACK_ENABLED=1
BETA_FEEDBACK_ATTACHMENTS_ENABLED=0
BETA_TASK_MODE_ENABLED=1
DOWNLOAD_GATE_ALLOW_DEMO_ROLES=0
BETA_AUTH_ENABLED=false
BETA_SESSION_SECRET=
BETA_VIEWER_PASSWORD=
BETA_CONTRIBUTOR_PASSWORD=
BETA_REVIEWER_PASSWORD=
BETA_ADMIN_PASSWORD=

# Browser-visible beta tools. Keep unset for production unless deliberately running a safe private beta.
NEXT_PUBLIC_LOCAL_BETA_ROLE_SWITCH=1
NEXT_PUBLIC_BETA_TASK_MODE_ENABLED=1
NEXT_PUBLIC_BETA_FEEDBACK_ENABLED=1

# Brand Hub ResourceSpace collection mapping.
BRAND_KIT_EASTER_2024_COLLECTION_ID=
BRAND_KIT_LOGO_COLLECTION_ID=
BRAND_KIT_SOCIAL_TEMPLATES_COLLECTION_ID=
