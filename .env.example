# Local-only demo defaults. Copy to .env and change passwords before any shared use.
RESOURCESPACE_PORT=8088

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=resourcespace
MYSQL_USER=resourcespace
MYSQL_PASSWORD=change-me-resourcespace

# Optional, for future ResourceSpace API automation.
RS_BASE_URL=http://localhost:8088
RS_API_USER=
RS_API_KEY=

# Preferred ResourceSpace server-only names. Do not prefix secrets with NEXT_PUBLIC.
RESOURCESPACE_BASE_URL=http://localhost:8088
RESOURCESPACE_API_USER=
RESOURCESPACE_API_KEY=
RESOURCESPACE_FIELD_MAP_JSON=
RESOURCESPACE_DEFAULT_COLLECTION_ID=

# Storage / custody readiness. Server-only.
S3_BUCKET=
S3_REGION=
S3_ACCESS_ROLE=
S3_PREVIEW_PREFIX=
S3_ORIGINAL_PREFIX=

GOOGLE_SHARED_DRIVE_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Identity / analytics readiness. Server-only unless explicitly documented otherwise.
SSO_PROVIDER=
SSO_CLIENT_ID=
PORTAL_USAGE_LOGGING=0
USAGE_ANALYTICS_DSN=

# Brand Hub ResourceSpace collection mapping.
BRAND_KIT_EASTER_2024_COLLECTION_ID=
BRAND_KIT_LOGO_COLLECTION_ID=
BRAND_KIT_SOCIAL_TEMPLATES_COLLECTION_ID=
