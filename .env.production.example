# Production template. Copy to .env on church PC/NAS and change every secret.
RESOURCESPACE_PORT=8088

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=resourcespace
MYSQL_USER=resourcespace
MYSQL_PASSWORD=change-me-resourcespace

RS_BASE_URL=https://stock-media.example.tjc.org
RS_API_USER=
RS_API_KEY=

# Launch guardrails. These are documentation/check values, not secrets.
TJC_DEPLOYMENT_TARGET=church-pc-nas
TJC_MIN_USABLE_STORAGE_TB=4
TJC_RECOMMENDED_USABLE_STORAGE_TB=8
TJC_ACCESS_CONTROL=cloudflare-access
TJC_MAX_BROWSER_UPLOAD_MB=100
AI_ENABLED=0
AI_MONTHLY_CAP_USD=25
